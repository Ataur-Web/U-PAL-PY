# U-Pal environment template. copy this file to .env and fill in the blanks.
# none of the values below are secrets, so committing this file is safe.

# ── LLM provider ─────────────────────────────────────────────────────────
# which provider serves chat by default. can still be flipped at runtime
# via POST /api/llm-config.
#   anthropic  cloud Claude (default, recommended)
#   ollama     local fallback, requires OLLAMA_URL reachable
LLM_PROVIDER=anthropic

# ── Anthropic Claude ─────────────────────────────────────────────────────
# get a key at https://console.anthropic.com/settings/keys
# models:
#   claude-3-5-haiku-latest   cheapest, great for demos (default)
#   claude-3-5-sonnet-latest  balanced
#   claude-sonnet-4-5         newer balanced
#   claude-opus-4-1           premium reasoning
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
ANTHROPIC_TEMPERATURE=0.4
ANTHROPIC_TIMEOUT_SECONDS=60
ANTHROPIC_MAX_TOKENS=1024

# ── Ollama (local fallback) ──────────────────────────────────────────────
# point at any OpenAI-compatible local LLM endpoint. Ollama is the default.
# for a Vercel-hosted frontend you will want ngrok to expose the local
# Ollama port as an HTTPS URL.
OLLAMA_URL=https://ollama-upal.ngrok.app
OLLAMA_MODEL=llama3.1:8b-instruct-q5_K_M
OLLAMA_NUM_CTX=4096
OLLAMA_TIMEOUT_SECONDS=60

# ── Chroma vector store (RAG) ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=uwtsd_corpus

# sentence-transformer used to embed corpus + queries.
# paraphrase-multilingual-MiniLM-L12-v2 handles Welsh↔English well.
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── Server ───────────────────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info

# comma-separated list of allowed CORS origins, or * for any
ALLOWED_ORIGINS=*

# ── RAG tuning ───────────────────────────────────────────────────────────
# cap on retrieved passages sent to the LLM
RAG_TOP_K=2
RAG_MAX_CHARS=500
