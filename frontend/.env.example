PORT=3000
ADMIN_PASSWORD=

# Ollama LLM integration (optional — bot works without it)
# Set to your ngrok/Cloudflare tunnel URL when running Ollama locally
OLLAMA_URL=https://your-ollama-tunnel.ngrok.app
OLLAMA_MODEL=llama3.1:8b

# Groq cloud LLM (optional — fallback for when Ollama is offline)
# Free tier (llama-3.1-8b-instant): ~30 requests/min, ~14,400/day
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Stanford CoreNLP enrichment (optional — improves NER + sentiment)
# Set to your Cloudflare tunnel URL when running CoreNLP locally
# e.g.  java -mx4g -cp "*" edu.stanford.nlp.pipeline.StanfordCoreNLPServer -port 9000 -timeout 60000
CORENLP_URL=https://your-corenlp-tunnel.trycloudflare.com

# Morphik RAG backend (optional — improves answers with ingested UWTSD document content)
# Set to your Oracle VM ngrok URL where Morphik is running, e.g. https://your-domain.ngrok.app
MORPHIK_URL=https://your-morphik-tunnel.ngrok.app
# Auth token set in morphik.toml → [auth] secret key (leave blank if bypass_auth_mode = true)
MORPHIK_AUTH_TOKEN=

# MongoDB (optional — feedback saved to local file without it)
MONGODB_URI=
